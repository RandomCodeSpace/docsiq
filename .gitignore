# Compiled binaries
/docsiq
/docsiq-*
/bin/

# Go build / test artifacts
*.test
*.out
*.prof
*.pprof
coverage.txt
profile.out

# Go workspace (per-developer, not checked in)
go.work
go.work.sum

# Local SQLite databases + WAL sidecars (test + dev runs)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Frontend — build artifacts
# Generic `dist/` ignored, BUT `ui/dist/` is intentionally tracked because
# `//go:embed` needs the built SPA present at `go build` time (we don't run
# npm during `go install`).
dist/
!ui/dist/
!ui/dist/**

# Frontend — tooling caches
ui/node_modules/
ui/.vite/
ui/coverage/
ui/*.tsbuildinfo

# Environment — never commit secrets
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db

# Claude Code session state (per-developer, regenerable)
.claude/

# Ad-hoc logs + tmp
*.log
*.tmp
*.bak
.superpowers/
