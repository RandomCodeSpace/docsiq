# Compiled binaries
/docsiq
/docsiq-*
/bin/

# Go build / test artifacts
*.test
*.out
*.prof
*.pprof
coverage.txt
profile.out

# Go workspace (per-developer, not checked in)
go.work
go.work.sum

# Local SQLite databases + WAL sidecars (test + dev runs)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Frontend — build artifacts
# `ui/dist/` IS committed in full so that `go install
# github.com/RandomCodeSpace/docsiq@vX.Y.Z` produces a working binary
# with the embedded SPA. The Go `//go:embed ui/dist` directive needs the
# real built assets present in the source tree at compile time; without
# them the binary serves a placeholder index.html and 404s on every
# /assets/* request. Re-build with `npm run build` and commit the
# resulting `ui/dist/` before tagging a release. CI also runs
# `npm run build` before `go build` so release binaries are always fresh.
# Other top-level dist/ build artefacts stay ignored.
dist/
!ui/dist/
!ui/dist/**

# Frontend — tooling caches
ui/node_modules/
ui/.vite/
ui/coverage/
ui/*.tsbuildinfo

# Frontend — Playwright E2E artifacts (generated, never committed)
ui/playwright-report/
ui/test-results/
ui/blob-report/
ui/playwright/.cache/

# Environment — never commit secrets
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db

# Claude Code session state (per-developer, regenerable)
.claude/

# Ad-hoc logs + tmp
*.log
*.tmp
*.bak
.superpowers/

# Internal planning/brainstorming scaffolding. Plans and specs written
# by the superpowers skills are development-workflow artifacts, not
# public docs — they go stale the moment features merge. Commit
# messages and PR descriptions carry the durable record.
docs/superpowers/
