# Compiled binaries
/docsiq
/docsiq-*
/bin/

# Go build / test artifacts
*.test
*.out
*.prof
*.pprof
coverage.txt
profile.out

# Go workspace (per-developer, not checked in)
go.work
go.work.sum

# Local SQLite databases + WAL sidecars (test + dev runs)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Frontend — build artifacts
# `ui/dist/` is generated by `npm run build` and never committed. We DO
# commit `ui/dist/index.html` — a placeholder the Go `//go:embed ui/dist`
# directive needs at compile time. CI builds the UI before every Go step
# so the embedded assets are always fresh.
dist/
!ui/dist/
ui/dist/*
!ui/dist/index.html

# Frontend — tooling caches
ui/node_modules/
ui/.vite/
ui/coverage/
ui/*.tsbuildinfo

# Environment — never commit secrets
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db

# Claude Code session state (per-developer, regenerable)
.claude/

# Ad-hoc logs + tmp
*.log
*.tmp
*.bak
.superpowers/
